{
  "name": "@skepsik/eslint-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared ESLint flat config for TypeScript projects",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp tsconfig.default.json dist/",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0"
  }
}
